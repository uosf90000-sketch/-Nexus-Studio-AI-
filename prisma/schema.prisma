// NEXUS-P1-001: Prisma schema for Phase 1 MVP
// Only includes tables required for: idea input -> summary + PRD -> save -> display

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Core entities
model Project {
  id        String   @id @default(cuid())
  title     String
  idea      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  documents ProjectDocument[]
  tasks Task[]
  costEntries CostEntry[]
  logs ExecutionLog[]
  councilSessions CouncilSession[]
}

model ProjectDocument {
  id        String   @id @default(cuid())
  projectId String
  type      String   @default("summary_and_prd") // Type of document (summary_and_prd for Phase 1)
  content   String   // JSON or markdown summary + short PRD
  createdAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model CostEntry {
  id        String   @id @default(cuid())
  projectId String
  provider  String   // "claude", etc
  model     String   // model identifier
  inputTokens Int
  outputTokens Int
  estimatedCost Float  // currency-agnostic
  actualCost    Float?
  createdAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model ExecutionLog {
  id              String   @id @default(cuid())
  projectId       String
  action          String   // "plan_created", "tasks_generated", etc
  status          String   // "success", "failed", "in_progress"
  provider        String?  // "claude"
  model           String?  // model identifier
  retryCount      Int      @default(0)
  elapsedMs       Int?     // elapsed time in milliseconds
  generatedCount  Int?     // number of items generated
  details         String?  // JSON metadata
  error           String?  // error message if failed
  createdAt       DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model TaskRun {
  id             String   @id @default(cuid())
  taskId         String
  status         String   @default("PENDING") // PENDING, RUNNING, SUCCESS, FAILED
  provider       String   // "claude"
  model          String   // model identifier
  generatedCode  String?  // generated code as text (Phase 2B)
  startedAt      DateTime @default(now())
  finishedAt     DateTime?
  inputTokens    Int?
  outputTokens   Int?
  estimatedCost  Float?
  actualCost     Float?
  retryCount     Int      @default(0)
  error          String?  // error message if failed
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  review Review?
  writtenFiles WrittenFile[]
  gitPush GitPush?
  pullRequest PullRequest?

  @@index([taskId])
}

model Task {
  id        String   @id @default(cuid())
  projectId String
  title     String
  description String
  order     Int      // sequence position (server-assigned: 1, 2, 3...)
  status    String   @default("PENDING") // PENDING, IN_PROGRESS, COMPLETED, FAILED
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  runs TaskRun[]

  @@index([projectId])
}

model Review {
  id           String   @id @default(cuid())
  taskRunId    String   @unique // one review per TaskRun
  verdict      String   // APPROVE, REQUEST_CHANGES, REJECT
  summary      String   // one-two sentence summary
  issues       String?  // JSON array of {severity, description}
  worksOnStack Boolean  // does code work on Next.js + Prisma + SQLite?
  provider     String   // "claude"
  model        String   // model identifier
  inputTokens  Int?
  outputTokens Int?
  estimatedCost Float?
  retryCount   Int      @default(0)
  error        String?  // error message if review failed
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  taskRun TaskRun @relation(fields: [taskRunId], references: [id], onDelete: Cascade)
  writtenFiles WrittenFile[]
  pullRequests PullRequest[]

  @@index([taskRunId])
}

model WrittenFile {
  id        String   @id @default(cuid())
  taskRunId String
  reviewId  String
  path      String   // relative path under generated/<projectId>/
  createdAt DateTime @default(now())

  taskRun TaskRun @relation(fields: [taskRunId], references: [id], onDelete: Cascade)
  review Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  @@index([taskRunId])
  @@index([reviewId])
}

model GitPush {
  id        String   @id @default(cuid())
  taskRunId String
  repo      String   // output repository (e.g., "user/project-repo")
  branch    String   // branch name (e.g., "nexus/<taskRunId>")
  commitSha String   // commit SHA hash
  createdAt DateTime @default(now())

  taskRun TaskRun @relation(fields: [taskRunId], references: [id], onDelete: Cascade)
  pullRequest PullRequest?

  @@index([taskRunId])
  @@unique([taskRunId]) // one push per TaskRun (for now)
}

model PullRequest {
  id        String   @id @default(cuid())
  taskRunId String   @unique // one PR per TaskRun
  reviewId  String
  gitPushId String   @unique // one PR per GitPush
  repo      String   // output repository (e.g., "user/project-repo")
  number    Int      // PR number on GitHub
  url       String   // full GitHub PR URL
  createdAt DateTime @default(now())

  taskRun TaskRun @relation(fields: [taskRunId], references: [id], onDelete: Cascade)
  review Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  gitPush GitPush @relation(fields: [gitPushId], references: [id], onDelete: Cascade)

  @@index([reviewId])
}

model AppSetting {
  key   String @id
  value String

  @@map("app_settings")
}

// NEXUS-P5-001: Council models
model CouncilSession {
  id              String   @id @default(cuid())
  projectId       String
  status          String   @default("ACTIVE") // ACTIVE, COMPLETED, FAILED
  verdict         String?  // PROCEED, REVISE, REJECT
  verdictReason   String?  // written explanation
  totalCost       Float    @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  messages CouncilMessage[]

  @@index([projectId])
}

model CouncilMessage {
  id              String   @id @default(cuid())
  sessionId       String
  round           Int      // 1, 2, etc
  role            String   // DIRECTOR, ENGINEER, ANALYST
  provider        String   // openai, anthropic, google
  model           String   // model identifier
  content         String   // full message text
  inputTokens     Int      @default(0)
  outputTokens    Int      @default(0)
  cost            Float    @default(0)
  order           Int      // sequence within round
  createdAt       DateTime @default(now())

  session CouncilSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([sessionId, round])
}

