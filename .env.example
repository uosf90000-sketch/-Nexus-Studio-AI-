# Database (Railway provides this automatically)
DATABASE_URL="postgresql://user:password@host:5432/nexus-studio-ai"

# AI Provider
ANTHROPIC_API_KEY="sk-ant-..."
ANTHROPIC_MODEL="claude-sonnet-5"

# GitHub (for output repo integration)
GITHUB_OUTPUT_TOKEN="ghp_..."
NEXUS_REPO_NAME="-Nexus-Studio-AI-"

# Cost tracking
COST_WARNING_THRESHOLD="100"
MAX_RETRY_COUNT="3"

# Access Control
ACCESS_CODE="your-secure-code-here"

# Node Environment
NODE_ENV="production"
