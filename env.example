# =========================================================
# Nexus Studio AI — Personal Prototype — Environment Example
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local or any real key. Only .env.example is committed.
# =========================================================

# ---- AI Provider (Phase 1: Claude only) ----
# The Planner adapter reads this. Required for the app to run.
ANTHROPIC_API_KEY=

# Model id used by the Claude adapter. Verify the current model string
# before relying on it — do not assume.
ANTHROPIC_MODEL=

# ---- Database (Phase 1: local SQLite) ----
# Prisma reads DATABASE_URL. SQLite lives in a local file.
DATABASE_URL="file:./dev.db"

# ---- Cost guardrails (read into AppSetting / config) ----
# Per-run soft cost warning threshold (currency-agnostic number).
COST_WARNING_THRESHOLD=

# Max attempts per task before it stops and surfaces the error.
MAX_RETRY_COUNT=2

# ---- App ----
# Local runs need no auth. When this is later deployed, add a simple
# access code here and gate the app on it — not before.
APP_ACCESS_CODE=
NODE_ENV=development
